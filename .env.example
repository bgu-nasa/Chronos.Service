# Discord Logger Configuration
# Set your Discord webhook URL here (leave empty for console-only logging)
DiscordLogger__DiscordWebhookUrl=

# Auth Configuration
# JWT secret key (must be at least 32 characters)
AuthConfiguration__SecretKey=

# Database Configuration
# PostgreSQL connection string (used by both the API and migrations)
ConnectionStrings__DefaultConnection=

# RabbitMQ (same shape as chronos-portal: copy to .local.env / .stg.env — do not commit secrets)
# Docker Compose: use hostname "rabbitmq". Local broker on host: use "localhost".
RabbitMQ__HostName=localhost
RabbitMQ__Port=5672
RabbitMQ__UserName=guest
RabbitMQ__Password=guest
RabbitMQ__VirtualHost=/
RabbitMQ__BatchQueueName=chronos.scheduling.batch
RabbitMQ__OnlineQueueName=chronos.scheduling.online
RabbitMQ__ExchangeName=chronos.scheduling